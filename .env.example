# ====================================
# Backend / Vercel Functions
# ====================================
# Create a new Supabase project at https://supabase.com
# Get these from: Project Settings → API → Project URL & Keys

# Supabase Project URL
# Example: https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Supabase Service Role Key (Backend only - NEVER expose to frontend)
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Get from: Project Settings → API → Service Role Key
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ====================================
# Frontend / Vite
# ====================================
# Supabase Anon Key (Safe to expose - used in frontend)
# Get from: Project Settings → API → Anon Key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ====================================
# Optional: Deployment
# ====================================
# Set to 'production' when deploying to Vercel
NODE_ENV=development
